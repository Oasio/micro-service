# Exemple de configuration — copier en .env.local et adapter.
# Le vrai .env.local NE DOIT PAS être commité (voir .gitignore).

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_in_env_local_please_32chars
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# MariaDB (config TP) ...
DATABASE_URL="mysql://root:root@127.0.0.1:3306/commande?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# ... ou SQLite zéro-install :
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> services appelés par Commande ###
CART_BASE_URL=http://localhost:8010
CATALOGUE_BASE_URL=http://localhost:8000
PAYMENT_BASE_URL=http://localhost:8020
CART_STUB_ENABLED=true
PAYMENT_STUB_ENABLED=true
###< services appelés par Commande ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=sync://
MESSENGER_FAILED_DSN=in-memory://
###< symfony/messenger ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8002
###< symfony/routing ###

###> service Auth (JWT — S12.3) ###
# URL JWKS de l'Auth (clé publique RS256 récupérée automatiquement).
JWT_JWKS_URL=http://10.72.200.53/api/auth/jwks
###< service Auth ###
