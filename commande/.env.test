###> symfony/framework-bundle ###
APP_ENV=test
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Base SQLite dédiée aux tests (le suffixe _test est ajouté par la config Doctrine when@test).
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> services appelés par Commande ###
# En test, les clients Panier/Catalogue/Paiement sont remplacés par des doubles déterministes.
CART_BASE_URL=http://localhost:8010
CATALOGUE_BASE_URL=http://localhost:8000
PAYMENT_BASE_URL=http://localhost:8020
CART_STUB_ENABLED=true
PAYMENT_STUB_ENABLED=true
###< services appelés par Commande ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=sync://
MESSENGER_FAILED_DSN=in-memory://
###< symfony/messenger ###

###> service Auth (JWT) ###
# En test, le provider de clé publique est remplacé par un double (clé de test) — l'URL n'est pas appelée.
JWT_JWKS_URL=http://localhost/api/auth/jwks
###< service Auth ###
