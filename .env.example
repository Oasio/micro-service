# Variables d'environnement du docker-compose (S8 étape 4).
# Copier ce fichier en ".env" et renseigner de vraies valeurs.
# Le vrai .env NE DOIT PAS être commité (il est dans .gitignore).

# Mot de passe de la base PostgreSQL du Catalogue
CATALOG_DB_PASSWORD=changeme_catalog

# Mot de passe root de la base MariaDB d'Avis-Clients
AVIS_DB_PASSWORD=changeme_avis

# Mot de passe root de la base MariaDB de Commande
COMMANDE_DB_PASSWORD=changeme_commande
